# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite – no setup needed):
DATABASE_URL=sqlite:///./leads.db

# Production (Neon PostgreSQL):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Pipeline ─────────────────────────────────────────────────────────────────
MAX_COMPANIES_PER_JOB=30
MAX_PAGES_PER_SITE=5
REQUEST_TIMEOUT=10
CRAWL_DELAY=1.0

# ── Quality thresholds ───────────────────────────────────────────────────────
MIN_LEAD_SCORE=30

# ── Worker / Crawler ─────────────────────────────────────────────────────────
# Shared secret between the deployed server and the local worker (set the
# same value on Render env vars AND on the machine running worker.py).
WORKER_SECRET=lorem-ipsum-dolor-sit-idk

# How many seconds before the server considers the worker "offline" (default 90).
WORKER_HEARTBEAT_TIMEOUT=90

# ── Local worker settings (only needed on the machine running worker.py) ─────
# Comma-separated server URL(s).  The worker tries each in order, so you can
# list both your *.onrender.com URL and a custom domain for redundancy.
#
# Local development (default – no config needed):
LEADPULSE_SERVER=http://localhost:8000
#
# Production (set this in your real .env, NOT here):
# LEADPULSE_SERVER=https://leadscraper-btn9.onrender.com,https://lead-scraper.dhruvm.dev

# Seconds between polling for new jobs (default 30).
# WORKER_POLL_INTERVAL=30
